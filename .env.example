NODE_ENV=production
PORT=3500
HOST=0.0.0.0

# Required before live persistence is enabled.
DATABASE_URL=postgres://user:password@localhost:5432/akashic_research_engine

# Required before AI assistant generation is enabled.
OPENAI_API_KEY=
