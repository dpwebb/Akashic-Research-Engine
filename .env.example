PORT=3500
HOST=0.0.0.0

# Docker Compose starts a local PostgreSQL container with these defaults.
POSTGRES_DB=akashic_research_engine
POSTGRES_USER=akashic
POSTGRES_PASSWORD=akashic_local_password
DATABASE_URL=postgres://akashic:akashic_local_password@127.0.0.1:5432/akashic_research_engine
# Docker Compose overrides the app container URL to use host akashic-research-engine-db.

# Required before AI assistant generation is enabled.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional shared provider keys used by current/future Hostinger apps.
DOCSTRANGE_API_KEY=
GOOGLE_GEMINI_SA_KEY=
GCS_BUCKET_NAME=
GCS_SERVICE_ACCOUNT_KEY=
POSTGRID_API_KEY=
POSTGRID_WEBHOOK_SECRET=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
